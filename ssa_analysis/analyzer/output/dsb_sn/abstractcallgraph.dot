digraph G {
	rankdir=TD;
	ranksep=1.5;
	nodesep=1;
	subgraph cluster_clients {
		style=invis;
		N_client [label="client", style=bold, shape=invhouse, color="orange"];
	}
	subgraph cluster_services {
		style=invis;
		N_Wrk2APIService_ReadHomeTimeline [label="Wrk2APIService.ReadHomeTimeline", style=bold, shape=box, color="blue"];
		N_HomeTimelineService_ReadHomeTimeline [label="HomeTimelineService.ReadHomeTimeline", style=bold, shape=box, color="blue"];
	}
	subgraph cluster_databases {
		style=invis;
	}
	N_client -> N_Wrk2APIService_ReadHomeTimeline [label="ReadHomeTimeline()", color=orange];
	N_Wrk2APIService_ReadHomeTimeline -> N_HomeTimelineService_ReadHomeTimeline [label="ReadHomeTimeline()", color=blue];
}
