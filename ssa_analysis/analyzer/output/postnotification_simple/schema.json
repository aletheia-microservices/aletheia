{
  "notifications_queue": {
    "name": "notifications_queue",
    "schemas": [
      {
        "name": "notification",
        "fields": [
          "notifications_queue.notification",
          "notifications_queue.notification.PostID",
          "notifications_queue.notification.ReqID"
        ],
        "constraints": [
          "FOREIGN_KEY notifications_queue.notification.PostID REFERENCES posts_db.post.PostID",
          "FOREIGN_KEY notifications_queue.notification.PostID REFERENCES posts_db.post[*].Value"
        ]
      }
    ]
  },
  "posts_db": {
    "name": "posts_db",
    "schemas": [
      {
        "name": "post",
        "fields": [
          "posts_db.post",
          "posts_db.post.Creator.Username",
          "posts_db.post.Mentions",
          "posts_db.post.PostID",
          "posts_db.post.ReqID",
          "posts_db.post.Text",
          "posts_db.post.Timestamp",
          "posts_db.post[*].Key",
          "posts_db.post[*].Value"
        ],
        "constraints": [
          "FOREIGN_KEY posts_db.post.ReqID REFERENCES notifications_queue.notification.ReqID"
        ]
      }
    ]
  }
}