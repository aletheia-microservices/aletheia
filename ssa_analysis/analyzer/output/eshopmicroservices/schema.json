{
  "basket_db": {
    "name": "basket_db",
    "schemas": [
      {
        "name": "basket",
        "fields": [
          "basket_db.basket",
          "basket_db.basket.Items",
          "basket_db.basket.Items[*]",
          "basket_db.basket.Items[*].Color",
          "basket_db.basket.Items[*].Price",
          "basket_db.basket.Items[*].ProductId",
          "basket_db.basket.Items[*].ProductName",
          "basket_db.basket.Items[*].Quantity",
          "basket_db.basket.TotalPrice",
          "basket_db.basket.UserName"
        ],
        "constraints": [
          "FOREIGN_KEY basket_db.basket.Items[*] REFERENCES catalog_db.product.Id",
          "FOREIGN_KEY basket_db.basket.Items[*] REFERENCES catalog_db.product.Name",
          "FOREIGN_KEY basket_db.basket.Items[*] REFERENCES catalog_db.product.Price",
          "FOREIGN_KEY basket_db.basket.Items[*].Price REFERENCES catalog_db.product.Price",
          "FOREIGN_KEY basket_db.basket.Items[*].ProductId REFERENCES catalog_db.product.Id",
          "FOREIGN_KEY basket_db.basket.Items[*].ProductName REFERENCES catalog_db.product.Name",
          "FOREIGN_KEY basket_db.basket.Items[*].ProductName REFERENCES discount_db.coupon.ProductName"
        ]
      }
    ]
  },
  "catalog_db": {
    "name": "catalog_db",
    "schemas": [
      {
        "name": "product",
        "fields": [
          "catalog_db.product",
          "catalog_db.product.Category",
          "catalog_db.product.Description",
          "catalog_db.product.Id",
          "catalog_db.product.ImageFile",
          "catalog_db.product.Name",
          "catalog_db.product.Price"
        ],
        "constraints": []
      }
    ]
  },
  "discount_db": {
    "name": "discount_db",
    "schemas": [
      {
        "name": "coupon",
        "fields": [
          "discount_db.coupon",
          "discount_db.coupon.Amount",
          "discount_db.coupon.Id",
          "discount_db.coupon.ProductName"
        ],
        "constraints": []
      }
    ]
  },
  "order_db": {
    "name": "order_db",
    "schemas": [
      {
        "name": "order",
        "fields": [
          "order_db.order"
        ],
        "constraints": []
      }
    ]
  },
  "order_queue": {
    "name": "order_queue",
    "schemas": [
      {
        "name": "notification",
        "fields": [
          "order_queue.notification",
          "order_queue.notification.AddressLine",
          "order_queue.notification.CVV",
          "order_queue.notification.CardName",
          "order_queue.notification.CardNumber",
          "order_queue.notification.Country",
          "order_queue.notification.CustomerId",
          "order_queue.notification.EmailAddress",
          "order_queue.notification.Expiration",
          "order_queue.notification.FirstName",
          "order_queue.notification.LastName",
          "order_queue.notification.PaymentMethod",
          "order_queue.notification.State",
          "order_queue.notification.TotalPrice",
          "order_queue.notification.UserName",
          "order_queue.notification.ZipCode"
        ],
        "constraints": []
      }
    ]
  }
}