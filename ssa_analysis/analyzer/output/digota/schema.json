{
  "orders_db": {
    "name": "orders_db",
    "schemas": [
      {
        "name": "orders",
        "fields": [
          "orders_db.orders",
          "orders_db.orders.Amount",
          "orders_db.orders.Currency",
          "orders_db.orders.Email",
          "orders_db.orders.Items",
          "orders_db.orders.Items[*].Parent",
          "orders_db.orders.Metadata",
          "orders_db.orders.Shipping"
        ],
        "constraints": [
          "FOREIGN_KEY orders_db.orders.Items[*].Parent REFERENCES skus_db.skus[0].Value",
          "FOREIGN_KEY orders_db.orders.Items[*].Parent REFERENCES skus_db.skus[*].Value"
        ]
      }
    ]
  },
  "payments_db": {
    "name": "payments_db",
    "schemas": null
  },
  "products_db": {
    "name": "products_db",
    "schemas": [
      {
        "name": "products",
        "fields": [
          "products_db.products",
          "products_db.products.Active",
          "products_db.products.Attributes",
          "products_db.products.Description",
          "products_db.products.Images",
          "products_db.products.Metadata",
          "products_db.products.Name",
          "products_db.products.Shippable",
          "products_db.products.Url",
          "products_db.products[*].Key",
          "products_db.products[*].Value",
          "products_db.products[0].Key",
          "products_db.products[0].Value"
        ],
        "constraints": []
      }
    ]
  },
  "queue": {
    "name": "queue",
    "schemas": null
  },
  "skus_db": {
    "name": "skus_db",
    "schemas": [
      {
        "name": "skus",
        "fields": [
          "skus_db.skus",
          "skus_db.skus.Active",
          "skus_db.skus.Attributes",
          "skus_db.skus.Currency",
          "skus_db.skus.Inventory",
          "skus_db.skus.Metadata",
          "skus_db.skus.Name",
          "skus_db.skus.PackageDimensions",
          "skus_db.skus.Parent",
          "skus_db.skus.Price",
          "skus_db.skus[*].Key",
          "skus_db.skus[*].Value",
          "skus_db.skus[0].Key",
          "skus_db.skus[0].Value"
        ],
        "constraints": [
          "FOREIGN_KEY skus_db.skus.Name REFERENCES products_db.products.Name"
        ]
      }
    ]
  }
