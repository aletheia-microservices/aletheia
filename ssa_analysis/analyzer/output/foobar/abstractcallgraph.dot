digraph G {
	rankdir=TD;
	ranksep=1.5;
	nodesep=1;
	subgraph cluster_clients {
		style=invis;
		N_client [label="client", style=bold, shape=invhouse, color="orange"];
	}
	subgraph cluster_services {
		style=invis;
		N_Frontend_ReadFooBar [label="Frontend.ReadFooBar", style=bold, shape=box, color="blue"];
		N_FooService_ReadFoo [label="FooService.ReadFoo", style=bold, shape=box, color="blue"];
		N_Frontend_WriteFooBar [label="Frontend.WriteFooBar", style=bold, shape=box, color="blue"];
		N_BarService_WriteBar [label="BarService.WriteBar", style=bold, shape=box, color="blue"];
		N_BarService_ReadBar [label="BarService.ReadBar", style=bold, shape=box, color="blue"];
		N_FooService_WriteFoo [label="FooService.WriteFoo", style=bold, shape=box, color="blue"];
	}
	subgraph cluster_databases {
		style=invis;
		N_foo_db_foo [label="foo_db.foo", style=bold, shape=cylinder, color="green"];
		N_bar_db_bar [label="bar_db.bar", style=bold, shape=cylinder, color="green"];
	}
	N_client -> N_Frontend_WriteFooBar [label="WriteFooBar()", color=orange];
	N_Frontend_WriteFooBar -> N_FooService_WriteFoo [label="WriteFoo()", color=blue];
	N_Frontend_WriteFooBar -> N_BarService_WriteBar [label="WriteBar()", color=blue];
	N_FooService_WriteFoo -> N_foo_db_foo [label="InsertOne()", color=green];
	N_BarService_WriteBar -> N_bar_db_bar [label="InsertOne()", color=green];
	N_client -> N_Frontend_ReadFooBar [label="ReadFooBar()", color=orange];
	N_Frontend_ReadFooBar -> N_FooService_ReadFoo [label="ReadFoo()", color=blue];
	N_Frontend_ReadFooBar -> N_BarService_ReadBar [label="ReadBar()", color=blue];
	N_FooService_ReadFoo -> N_foo_db_foo [label="FindOne()", color=green];
	N_BarService_ReadBar -> N_bar_db_bar [label="FindOne()", color=green];
}
