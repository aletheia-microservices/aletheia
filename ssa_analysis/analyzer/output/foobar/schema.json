{
  "bar_db": {
    "name": "bar_db",
    "schemas": [
      {
        "name": "bar",
        "fields": [
          "bar_db.bar",
          "bar_db.bar.BarID",
          "bar_db.bar.FooID",
          "bar_db.bar.Text"
        ],
        "constraints": []
      }
    ]
  },
  "foo_db": {
    "name": "foo_db",
    "schemas": [
      {
        "name": "foo",
        "fields": [
          "foo_db.foo",
          "foo_db.foo.FooID",
          "foo_db.foo.Text"
        ],
        "constraints": [
          "FOREIGN_KEY foo_db.foo.FooID REFERENCES bar_db.bar.FooID [MANDATORY]",
          "FOREIGN_KEY foo_db.foo.Text REFERENCES bar_db.bar.Text [MANDATORY]"
        ]
      }
    ]
  }
}