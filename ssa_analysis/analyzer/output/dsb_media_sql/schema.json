{
  "castinfo_db": {
    "name": "castinfo_db",
    "schemas": [
      {
        "name": "castinfo",
        "fields": [
          "castinfo_db.castinfo",
          "castinfo_db.castinfo.castinfoid",
          "castinfo_db.castinfo.gender",
          "castinfo_db.castinfo.intro",
          "castinfo_db.castinfo.name"
        ],
        "constraints": [
          "FOREIGN_KEY castinfo_db.castinfo.castinfoid REFERENCES movieinfo_db.movieinfo.castid [MANDATORY]",
          "PRIMARY KEY (castinfo_db.castinfo.castinfoid)"
        ]
      }
    ]
  },
  "movieid_db": {
    "name": "movieid_db",
    "schemas": [
      {
        "name": "movieid",
        "fields": [
          "movieid_db.movieid",
          "movieid_db.movieid.movieid",
          "movieid_db.movieid.title"
        ],
        "constraints": [
          "PRIMARY KEY (movieid_db.movieid.movieid)",
          "UNIQUE (movieid_db.movieid.title)"
        ]
      }
    ]
  },
  "movieinfo_db": {
    "name": "movieinfo_db",
    "schemas": [
      {
        "name": "movieinfo",
        "fields": [
          "movieinfo_db.movieinfo",
          "movieinfo_db.movieinfo.castid",
          "movieinfo_db.movieinfo.movieid",
          "movieinfo_db.movieinfo.plotid",
          "movieinfo_db.movieinfo.title"
        ],
        "constraints": [
          "FOREIGN_KEY movieinfo_db.movieinfo.movieid REFERENCES movieid_db.movieid.movieid [MANDATORY]",
          "FOREIGN_KEY movieinfo_db.movieinfo.title REFERENCES movieid_db.movieid.title [MANDATORY]",
          "PRIMARY KEY (movieinfo_db.movieinfo.movieid)"
        ]
      }
    ]
  },
  "plot_db": {
    "name": "plot_db",
    "schemas": [
      {
        "name": "plot",
        "fields": [
          "plot_db.plot",
          "plot_db.plot.plot",
          "plot_db.plot.plotid"
        ],
        "constraints": [
          "FOREIGN_KEY plot_db.plot.plotid REFERENCES movieinfo_db.movieinfo.plotid [MANDATORY]",
          "PRIMARY KEY (plot_db.plot.plotid)"
        ]
      }
    ]
  }
}