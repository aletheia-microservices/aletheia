		N_ComposePostService_ComposePost [label="ComposePostService.ComposePost", style=bold, shape=box, color="blue"];
		N_TextService_ComposeText [label="TextService.ComposeText", style=bold, shape=box, color="blue"];
		N_MediaService_ComposeMedia [label="MediaService.ComposeMedia", style=bold, shape=box, color="blue"];
		N_UserTimelineService_WriteUserTimeline [label="UserTimelineService.WriteUserTimeline", style=bold, shape=box, color="blue"];
		N_UrlShortenService_ComposeUrls [label="UrlShortenService.ComposeUrls", style=bold, shape=box, color="blue"];
	}
	subgraph cluster_databases {
		style=invis;
		N_socialgraph_cache_followers [label="socialgraph_cache.followers", style=bold, shape=cylinder, color="green"];
		N_socialgraph_db_socialgraph [label="socialgraph_db.socialgraph", style=bold, shape=cylinder, color="green"];
