	N_ComposePostService_ComposePost -> N_UserTimelineService_WriteUserTimeline [label="WriteUserTimeline()", color=blue];
	N_ComposePostService_ComposePost -> N_HomeTimelineService_WriteHomeTimeline [label="WriteHomeTimeline()", color=blue];
	N_TextService_ComposeText -> N_UrlShortenService_ComposeUrls [label="ComposeUrls()", color=blue];
	N_TextService_ComposeText -> N_UserMentionService_ComposeUserMentions [label="ComposeUserMentions()", color=blue];
	N_PostStorageService_StorePost -> N_post_db_post [label="InsertOne()", color=green];
	N_UserTimelineService_WriteUserTimeline -> N_usertimeline_db_usertimeline [label="FindMany()", color=green];
