digraph G {
	rankdir=TD;
	ranksep=1.5;
	nodesep=1;
	subgraph cluster_clients {
		style=invis;
		N_client [label="client", style=bold, shape=invhouse, color="orange"];
	}
	subgraph cluster_services {
		style=invis;
		N_UserService_CheckUser [label="UserService.CheckUser", style=bold, shape=box, color="blue"];
		N_ReservationService_MakeReservation [label="ReservationService.MakeReservation", style=bold, shape=box, color="blue"];
		N_SearchService_Nearby [label="SearchService.Nearby", style=bold, shape=box, color="blue"];
		N_FrontEndService_UserHandler [label="FrontEndService.UserHandler", style=bold, shape=box, color="blue"];
		N_RecommendationService_GetRecommendations [label="RecommendationService.GetRecommendations", style=bold, shape=box, color="blue"];
		N_FrontEndService_RecommendHandler [label="FrontEndService.RecommendHandler", style=bold, shape=box, color="blue"];
		N_ProfileService_GetProfiles [label="ProfileService.GetProfiles", style=bold, shape=box, color="blue"];
		N_FrontEndService_ReservationHandler [label="FrontEndService.ReservationHandler", style=bold, shape=box, color="blue"];
		N_GeoService_Nearby [label="GeoService.Nearby", style=bold, shape=box, color="blue"];
		N_FrontEndService_SearchHandler [label="FrontEndService.SearchHandler", style=bold, shape=box, color="blue"];
		N_ReservationService_CheckAvailability [label="ReservationService.CheckAvailability", style=bold, shape=box, color="blue"];
		N_RateService_GetRates [label="RateService.GetRates", style=bold, shape=box, color="blue"];
	}
	subgraph cluster_databases {
		style=invis;
		N_rate_db_inventory [label="rate_db.inventory", style=bold, shape=cylinder, color="green"];
		N_profile_db_hotels [label="profile_db.hotels", style=bold, shape=cylinder, color="green"];
		N_reservation_db_reservation [label="reservation_db.reservation", style=bold, shape=cylinder, color="green"];
		N_reservation_cache_* [label="reservation_cache.*", style=bold, shape=cylinder, color="green"];
		N_reservation_db_number [label="reservation_db.number", style=bold, shape=cylinder, color="green"];
		N_rate_cache_* [label="rate_cache.*", style=bold, shape=cylinder, color="green"];
		N_profile_cache_* [label="profile_cache.*", style=bold, shape=cylinder, color="green"];
		N_reservation_cache__cap [label="reservation_cache._cap", style=bold, shape=cylinder, color="green"];
	}
	N_client -> N_FrontEndService_RecommendHandler [label="RecommendHandler()", color=orange];
	N_FrontEndService_RecommendHandler -> N_RecommendationService_GetRecommendations [label="GetRecommendations()", color=blue];
	N_FrontEndService_RecommendHandler -> N_ProfileService_GetProfiles [label="GetProfiles()", color=blue];
	N_ProfileService_GetProfiles -> N_profile_cache_* [label="Get()", color=green];
	N_ProfileService_GetProfiles -> N_profile_db_hotels [label="FindOne()", color=green];
	N_ProfileService_GetProfiles -> N_profile_cache_* [label="Put()", color=green];
	N_client -> N_FrontEndService_ReservationHandler [label="ReservationHandler()", color=orange];
	N_FrontEndService_ReservationHandler -> N_UserService_CheckUser [label="CheckUser()", color=blue];
	N_FrontEndService_ReservationHandler -> N_ReservationService_MakeReservation [label="MakeReservation()", color=blue];
	N_ReservationService_MakeReservation -> N_reservation_cache_* [label="Get()", color=green];
	N_ReservationService_MakeReservation -> N_reservation_db_reservation [label="FindMany()", color=green];
	N_ReservationService_MakeReservation -> N_reservation_cache__cap [label="Get()", color=green];
	N_ReservationService_MakeReservation -> N_reservation_db_number [label="FindOne()", color=green];
	N_ReservationService_MakeReservation -> N_reservation_cache__cap [label="Put()", color=green];
	N_ReservationService_MakeReservation -> N_reservation_db_reservation [label="InsertOne()", color=green];
	N_ReservationService_MakeReservation -> N_reservation_cache_* [label="Put()", color=green];
	N_client -> N_FrontEndService_SearchHandler [label="SearchHandler()", color=orange];
	N_FrontEndService_SearchHandler -> N_SearchService_Nearby [label="Nearby()", color=blue];
	N_FrontEndService_SearchHandler -> N_ReservationService_CheckAvailability [label="CheckAvailability()", color=blue];
	N_FrontEndService_SearchHandler -> N_ProfileService_GetProfiles [label="GetProfiles()", color=blue];
	N_SearchService_Nearby -> N_GeoService_Nearby [label="Nearby()", color=blue];
	N_SearchService_Nearby -> N_RateService_GetRates [label="GetRates()", color=blue];
	N_RateService_GetRates -> N_rate_cache_* [label="Get()", color=green];
	N_RateService_GetRates -> N_rate_db_inventory [label="FindMany()", color=green];
	N_RateService_GetRates -> N_rate_cache_* [label="Put()", color=green];
	N_ReservationService_CheckAvailability -> N_reservation_cache_* [label="Get()", color=green];
	N_ReservationService_CheckAvailability -> N_reservation_db_reservation [label="FindMany()", color=green];
	N_ReservationService_CheckAvailability -> N_reservation_cache__cap [label="Get()", color=green];
	N_ReservationService_CheckAvailability -> N_reservation_cache_* [label="Put()", color=green];
	N_ReservationService_CheckAvailability -> N_reservation_db_number [label="FindOne()", color=green];
	N_ReservationService_CheckAvailability -> N_reservation_cache__cap [label="Put()", color=green];
	N_client -> N_FrontEndService_UserHandler [label="UserHandler()", color=orange];
	N_FrontEndService_UserHandler -> N_UserService_CheckUser [label="CheckUser()", color=blue];
}
