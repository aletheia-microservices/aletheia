{
  "cart_db": {
    "name": "cart_db",
    "schemas": [
      {
        "name": "carts",
        "fields": [
          "cart_db.carts",
          "cart_db.carts.ID",
          "cart_db.carts.Items",
          "cart_db.carts.Items[*]",
          "cart_db.carts.Items[*].ID"
        ],
        "constraints": [
          "FOREIGN_KEY cart_db.carts.Items[*].ID REFERENCES catalogue_db.catalogue.ID"
        ]
      }
    ]
  },
  "catalogue_db": {
    "name": "catalogue_db",
    "schemas": [
      {
        "name": "catalogue",
        "fields": [
          "catalogue_db.catalogue",
          "catalogue_db.catalogue.ID"
        ],
        "constraints": []
      }
    ]
  },
  "order_db": {
    "name": "order_db",
    "schemas": [
      {
        "name": "orders",
        "fields": [
          "order_db.orders",
          "order_db.orders.Address",
          "order_db.orders.Card",
          "order_db.orders.CustomerID",
          "order_db.orders.Date",
          "order_db.orders.ID",
          "order_db.orders.Items",
          "order_db.orders.Shipment",
          "order_db.orders.Shipment.ID",
          "order_db.orders.Shipment.Status",
          "order_db.orders.Total"
        ],
        "constraints": [
          "FOREIGN_KEY order_db.orders.Shipment REFERENCES ship_queue.notification",
          "FOREIGN_KEY order_db.orders.Shipment REFERENCES ship_db.shipments [MANDATORY]"
        ]
      }
    ]
  },
  "ship_db": {
    "name": "ship_db",
    "schemas": [
      {
        "name": "shipments",
        "fields": [
          "ship_db.shipments",
          "ship_db.shipments.ID",
          "ship_db.shipments.Name",
          "ship_db.shipments.Status"
        ],
        "constraints": [
          "FOREIGN_KEY ship_db.shipments.Name REFERENCES order_db.orders.CustomerID [MANDATORY]",
          "FOREIGN_KEY ship_db.shipments.Status REFERENCES order_db.orders.Shipment.Status [MANDATORY]",
          "FOREIGN_KEY ship_db.shipments.ID REFERENCES order_db.orders.ID [MANDATORY]",
          "FOREIGN_KEY ship_db.shipments.ID REFERENCES order_db.orders.Shipment.ID [MANDATORY]",
          "FOREIGN_KEY ship_db.shipments REFERENCES ship_queue.notification"
        ]
      }
    ]
  },
  "ship_queue": {
    "name": "ship_queue",
    "schemas": [
      {
        "name": "notification",
        "fields": [
          "ship_queue.notification",
          "ship_queue.notification.ID",
          "ship_queue.notification.Name",
          "ship_queue.notification.Status"
        ],
        "constraints": [
          "FOREIGN_KEY ship_queue.notification.Name REFERENCES order_db.orders.CustomerID [MANDATORY]",
          "FOREIGN_KEY ship_queue.notification.Status REFERENCES order_db.orders.Shipment.Status [MANDATORY]",
          "FOREIGN_KEY ship_queue.notification.ID REFERENCES order_db.orders.ID [MANDATORY]",
          "FOREIGN_KEY ship_queue.notification.ID REFERENCES order_db.orders.Shipment.ID [MANDATORY]"
        ]
      }
    ]
  },
  "user_db": {
    "name": "user_db",
    "schemas": [
      {
        "name": "users",
        "fields": [
          "user_db.users",
          "user_db.users.Addresses",
          "user_db.users.Cards",
          "user_db.users.Email",
          "user_db.users.FirstName",
          "user_db.users.LastName",
          "user_db.users.Password",
          "user_db.users.UserID",
          "user_db.users.Username",
          "user_db.users.username"
        ],
        "constraints": []
      }
    ]
  }
}