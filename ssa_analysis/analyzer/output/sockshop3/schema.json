{
  "cart_db": {
    "name": "cart_db",
    "schemas": [
      {
        "name": "carts",
        "fields": [
          "cart_db.carts",
          "cart_db.carts.ID",
          "cart_db.carts.Items",
          "cart_db.carts.Items[*]",
          "cart_db.carts.Items[*].ID",
          "cart_db.carts.Items[*].Quantity",
          "cart_db.carts.Items[*].UnitPrice"
        ],
        "constraints": [
          "FOREIGN_KEY cart_db.carts.ID REFERENCES user_db.users.UserID",
          "FOREIGN_KEY cart_db.carts.Items[*].ID REFERENCES catalogue_db.sock.ID",
          "FOREIGN_KEY cart_db.carts.Items[*].UnitPrice REFERENCES catalogue_db.sock.Price"
        ]
      }
    ]
  },
  "catalogue_db": {
    "name": "catalogue_db",
    "schemas": [
      {
        "name": "sock",
        "fields": [
          "catalogue_db.sock",
          "catalogue_db.sock.ID",
          "catalogue_db.sock.ImageURL",
          "catalogue_db.sock.ImageURL_1",
          "catalogue_db.sock.ImageURL_2",
          "catalogue_db.sock.Price",
          "catalogue_db.sock.TagString",
          "catalogue_db.sock.Tags"
        ],
        "constraints": []
      },
      {
        "name": "tag",
        "fields": [],
        "constraints": []
      }
    ]
  },
  "order_db": {
    "name": "order_db",
    "schemas": [
      {
        "name": "orders",
        "fields": [
          "order_db.orders",
          "order_db.orders.Address",
          "order_db.orders.Card",
          "order_db.orders.CustomerID",
          "order_db.orders.Date",
          "order_db.orders.ID",
          "order_db.orders.Items",
          "order_db.orders.Items[*]",
          "order_db.orders.Items[*].Quantity",
          "order_db.orders.Items[*].UnitPrice",
          "order_db.orders.Shipment",
          "order_db.orders.Shipment.ID",
          "order_db.orders.Shipment.Name",
          "order_db.orders.Shipment.Status"
        ],
        "constraints": [
          "FOREIGN_KEY order_db.orders.Address REFERENCES user_db.users.Addresses",
          "FOREIGN_KEY order_db.orders.Card REFERENCES user_db.users.Cards",
          "FOREIGN_KEY order_db.orders.CustomerID REFERENCES user_db.users.UserID",
          "FOREIGN_KEY order_db.orders.ID REFERENCES ship_db.shipments.ID [MANDATORY]",
          "FOREIGN_KEY order_db.orders.ID REFERENCES ship_queue.notification.ID [MANDATORY]",
          "FOREIGN_KEY order_db.orders.Items REFERENCES cart_db.carts.Items",
          "FOREIGN_KEY order_db.orders.Items[*] REFERENCES cart_db.carts.Items[*]",
          "FOREIGN_KEY order_db.orders.Items[*].Quantity REFERENCES cart_db.carts.Items[*].Quantity",
          "FOREIGN_KEY order_db.orders.Items[*].UnitPrice REFERENCES catalogue_db.sock.Price [T]",
          "FOREIGN_KEY order_db.orders.Shipment REFERENCES ship_db.shipments [MANDATORY]",
          "FOREIGN_KEY order_db.orders.Shipment REFERENCES ship_queue.notification [MANDATORY]",
          "FOREIGN_KEY order_db.orders.Shipment.Name REFERENCES user_db.users.UserID [T]",
          "FOREIGN_KEY order_db.orders.Shipment.Status REFERENCES ship_db.shipments.Status [MANDATORY]",
          "FOREIGN_KEY order_db.orders.Shipment.Status REFERENCES ship_queue.notification.Status [MANDATORY]"
        ]
      }
    ]
  },
  "ship_db": {
    "name": "ship_db",
    "schemas": [
      {
        "name": "shipments",
        "fields": [
          "ship_db.shipments",
          "ship_db.shipments.ID",
          "ship_db.shipments.Name",
          "ship_db.shipments.Status"
        ],
        "constraints": [
          "FOREIGN_KEY ship_db.shipments REFERENCES ship_queue.notification",
          "FOREIGN_KEY ship_db.shipments.ID REFERENCES ship_queue.notification.ID",
          "FOREIGN_KEY ship_db.shipments.Name REFERENCES user_db.users.UserID"
        ]
      }
    ]
  },
  "ship_queue": {
    "name": "ship_queue",
    "schemas": [
      {
        "name": "notification",
        "fields": [
          "ship_queue.notification",
          "ship_queue.notification.ID",
          "ship_queue.notification.Name",
          "ship_queue.notification.Status"
        ],
        "constraints": [
          "FOREIGN_KEY ship_queue.notification.Name REFERENCES user_db.users.UserID"
        ]
      }
    ]
  },
  "user_db": {
    "name": "user_db",
    "schemas": [
      {
        "name": "users",
        "fields": [
          "user_db.users",
          "user_db.users.Addresses",
          "user_db.users.Cards",
          "user_db.users.Email",
          "user_db.users.FirstName",
          "user_db.users.LastName",
          "user_db.users.Password",
          "user_db.users.Salt",
          "user_db.users.UserID",
          "user_db.users.Username",
          "user_db.users._id"
        ],
        "constraints": []
      }
    ]
  }
}