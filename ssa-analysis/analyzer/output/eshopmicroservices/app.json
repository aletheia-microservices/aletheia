{
  "name": "eshopmicroservices",
  "databases": [
    "basket_db",
    "catalog_db",
    "discount_db",
    "order_db",
    "order_queue"
  ],
  "services": [
    {
      "name": "BasketService",
      "path": "github.com/blueprint-uservices/blueprint/examples/eshopmicroservices/workflow/basket.BasketService",
      "pkg": "basket",
      "impl": "BasketServiceImpl",
      "fields": [
        "database #0 (basket_db)",
        "queue #1 (order_queue)",
        "discountService #2 (discount_service)"
      ],
      "methods": [
        "CheckoutBasket",
        "DeleteBasket",
        "GetBasket",
        "StoreBasket"
      ],
      "services": [
        "DiscountService"
      ],
      "databases": []
    },
    {
      "name": "CatalogService",
      "path": "github.com/blueprint-uservices/blueprint/examples/eshopmicroservices/workflow/catalog.CatalogService",
      "pkg": "catalog",
      "impl": "CatalogServiceImpl",
      "fields": [
        "database #0 (catalog_db)"
      ],
      "methods": [
        "CreateProduct",
        "DeleteProduct",
        "GetProductByCategory",
        "GetProductById",
        "GetProducts",
        "Run"
      ],
      "services": [],
      "databases": []
    },
    {
      "name": "DiscountService",
      "path": "github.com/blueprint-uservices/blueprint/examples/eshopmicroservices/workflow/discount.DiscountService",
      "pkg": "discount",
      "impl": "DiscountServiceImpl",
      "fields": [
        "database #0 (discount_db)"
      ],
      "methods": [
        "CreateDiscount",
        "DeleteDiscount",
        "GetDiscount",
        "UpdateDiscount"
      ],
      "services": [],
      "databases": []
    },
    {
      "name": "OrderService",
      "path": "github.com/blueprint-uservices/blueprint/examples/eshopmicroservices/workflow/order.OrderService",
      "pkg": "order",
      "impl": "OrderServiceImpl",
      "fields": [
        "database #0 (order_db)",
        "queue #1 (order_queue)"
      ],
      "methods": [
        "CreateNewOrder",
        "DeleteOrder",
        "GetOrdersByCustomer",
        "Run",
        "UpdateOrder"
      ],
      "services": [],
      "databases": []
    },
    {
      "name": "WebApp",
      "path": "github.com/blueprint-uservices/blueprint/examples/eshopmicroservices/workflow/web.WebApp",
      "pkg": "web",
      "impl": "WebAppImpl",
      "fields": [
        "basketService #0 (basket_service)",
        "catalogService #1 (catalog_service)",
        "discountService #2 (discount_service)",
        "orderService #3 (order_service)",
        "customerId #4"
      ],
      "methods": [
        "OnGetOrdersAsync",
        "OnGetProductsAsync",
        "OnPostAddToCartAsync",
        "OnPostCheckoutAsync",
        "OnPostRemoveToCartAsync"
      ],
      "services": [
        "BasketService",
        "CatalogService",
        "DiscountService",
        "OrderService"
      ],
      "databases": []
    }
  ]
}