{
  "cart_db": {
    "name": "cart_db",
    "schemas": [
      {
        "name": "carts",
        "fields": [
          "cart_db.carts",
          "cart_db.carts.ID",
          "cart_db.carts.Items",
          "cart_db.carts.Items[*]",
          "cart_db.carts.Items[*].ID",
          "cart_db.carts.Items[*].Quantity",
          "cart_db.carts.Items[*].UnitPrice"
        ],
        "constraints": [
          "FOREIGN_KEY cart_db.carts.ID REFERENCES user_db.user.User.UserID",
          "FOREIGN_KEY cart_db.carts.Items[*].ID REFERENCES catalogue_db.sock.SockID",
          "FOREIGN_KEY cart_db.carts.Items[*].UnitPrice REFERENCES catalogue_db.sock.Price"
        ]
      }
    ]
  },
  "catalogue_db": {
    "name": "catalogue_db",
